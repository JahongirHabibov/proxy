# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Email for certificate expiry notifications
ACME_EMAIL=your@email.com

# ── Traefik Dashboard ─────────────────────────────────────────────────────────
# Domain where the Traefik dashboard will be accessible
TRAEFIK_DOMAIN=proxy.yourdomain.com

# BasicAuth credentials for the dashboard.
# Generate with:   make gen-password
# Then paste the output here (the $$ escaping is required by Docker Compose).
DASHBOARD_USERS=admin:$$apr1$$example$$hashedpasswordhere

# ── Docker Network ────────────────────────────────────────────────────────────
# Name of the shared Docker network between proxy and all app containers.
# App projects must reference this exact name with: external: true
NETWORK_NAME=proxy-network
